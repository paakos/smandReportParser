model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["DirectLake - samplingdata"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["DirectLakeOnOneLakeInWeb"]

ref table Address
ref table ProductModel
ref table ProductCategory
ref table Customer
ref table SalesOrderHeader
ref table ProductModelProductDescription
ref table ProductDescription
ref table Product
ref table SalesOrderDetail
ref table CustomerAddress

